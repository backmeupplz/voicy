{
  "name": "voicy",
  "version": "1.0.0",
  "description": "Speech-to-text Telegram bot",
  "main": "dist/app.js",
  "private": false,
  "license": "MIT",
  "author": "backmeupplz <backmeupplz@gmail.com>",
  "scripts": {
    "distribute": "node dist/app.js",
    "develop": "concurrently -k -i -p \"[{name}]\" -n \"Node,TypeScript\" -c \"yellow.bold,cyan.bold\" \"yarn watch-js\" \"yarn watch-ts\"",
    "build-ts": "tsc --skipLibCheck",
    "test:qa-vnext": "node scripts/qa-vnext-proof.js",
    "test:worker-client": "node scripts/worker-client-proof.js",
    "test:worker-e2e": "node scripts/worker-e2e-proof.js",
    "test:worker-local-stt": "node scripts/local-whisper-worker-proof.js",
    "test:whisper-transcriber": "node scripts/whisper-transcriber-proof.js",
    "test:worker-api": "node scripts/worker-api-proof.js",
    "test:language-selection": "node scripts/language-selection-proof.js",
    "test:progress-policy": "node scripts/progress-policy-proof.js",
    "test:progress-status-format": "node scripts/progress-status-format-proof.js",
    "test:media-coverage": "node scripts/media-coverage-proof.js",
    "test:report-sanitizer": "node scripts/report-sanitizer-proof.js",
    "test:source-url-security": "node scripts/source-url-security-proof.js",
    "test:transcription-abuse-limits": "node scripts/transcription-abuse-limits-proof.js",
    "test:golden-borodutch-allowance": "node scripts/golden-borodutch-allowance-proof.js",
    "test:donation-wall": "node scripts/donation-wall-proof.js",
    "test:telegram-runtime": "node scripts/telegram-runtime-check.js",
    "test:id-command": "node scripts/id-command-proof.js",
    "test:local-runtime-health": "node scripts/local-runtime-health.js",
    "test:stripe-webhook": "node scripts/stripe-webhook-proof.js",
    "qa:telegram-upload": "node scripts/telegram-web-upload-qa.mjs",
    "worker:create-client": "node scripts/create-worker-client.js",
    "security:scrub-source-urls": "node scripts/scrub-token-bearing-source-urls.js",
    "worker:install-macos-test-launchd": "node scripts/install-macos-test-worker-launchd.js --load",
    "worker:print-macos-test-launchd": "node scripts/install-macos-test-worker-launchd.js --print",
    "worker:run": "node dist/workerClient/runWindowsWorker.js",
    "watch-ts": "tsc -w --skipLibCheck",
    "watch-js": "nodemon dist/app.js",
    "audit-locales": "node scripts/audit-localizations.js",
    "audit:commands": "node scripts/audit-bot-commands.js",
    "pretty": "prettier --check src",
    "lint": "yarn pretty && eslint --max-warnings 0 --ext ts,tsx,json src"
  },
  "dependencies": {
    "@grammyjs/i18n": "^0.5.1",
    "@grammyjs/runner": "^1.0.4",
    "@typegoose/typegoose": "^9.13.2",
    "axios": "^0.31.1",
    "express": "^4.22.1",
    "grammy": "^1.7.3",
    "js-yaml": "^4.1.1",
    "mongoose": "6.13.6",
    "mongoose-findorcreate": "^3.0.0",
    "stripe": "^14.25.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^16.18.126",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "concurrently": "^6.5.1",
    "dotenv": "^10.0.0",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-prettier": "^4.2.5",
    "eslint-plugin-sort-imports-es6-autofix": "^0.6.0",
    "module-alias": "^2.3.4",
    "nodemon": "^2.0.22",
    "prettier": "^2.8.8",
    "typescript": "^4.9.5"
  },
  "_moduleAliases": {
    "@": "dist"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
